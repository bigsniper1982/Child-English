# Copy to /etc/kids-english-ai.env, fill in real values, and chmod 600.

# Required: a long random string used to sign session cookies.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-value

# Required: hashed family password. Generate with:
#   python manage.py hash-password
FAMILY_PASSWORD_HASH=

# SQLite database path (absolute recommended in production).
DATABASE=/opt/kids-english-ai/instance/app.db

# Set to 1 when served over HTTPS so the session cookie is Secure-only.
SESSION_COOKIE_SECURE=1

# Login rate limiting (optional; these are the defaults).
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300
